#!/bin/sh
# Maven Wrapper shell script

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
    fi
else
    JAVACMD="java"
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH."
fi

# Look for the Maven wrapper jar
WRAPPER_LAUNCHER=""
if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" ]; then
    WRAPPER_LAUNCHER="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
elif [ -f "$0" ]; then
    SCRIPT_DIR="$( cd "$( dirname "$0" )" && pwd )"
    if [ -f "$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.jar" ]; then
        WRAPPER_LAUNCHER="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.jar"
    fi
fi

if [ -z "$WRAPPER_LAUNCHER" ]; then
    # Try the .mvn/wrapper directory relative to the project base dir
    WRAPPER_LAUNCHER="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
fi

exec "$JAVACMD" \
    $MAVEN_OPTS \
    $MAVEN_DEBUG_OPTS \
    -classpath "$WRAPPER_LAUNCHER" \
    "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
    org.apache.maven.wrapper.MavenWrapperMain \
    "$@"
